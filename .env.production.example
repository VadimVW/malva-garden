# Copy to .env on the VPS (same directory as docker-compose.prod.yml)

POSTGRES_PASSWORD=change-me-long-random
JWT_SECRET=change-me-long-random-jwt

# Public URLs (no trailing slash on origins; API URL includes /api/v1)
# Production domains (Cloudflare → 159.195.148.48):
WEB_ORIGIN=https://malva-garden.com
ADMIN_ORIGIN=https://admin.malva-garden.com
API_PUBLIC_ORIGIN=https://malva-garden.com
NEXT_PUBLIC_API_URL=https://malva-garden.com/api/v1
NEXT_PUBLIC_SITE_URL=https://malva-garden.com
# Google Search Console (HTML tag method) — docs/SEO_GOOGLE.md; rebuild web після зміни
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Caddy Let's Encrypt (реальний email для сертифікатів)
ACME_EMAIL=you@example.com

EMAIL_VERIFICATION_DEV=false
SMTP_ENABLED=false
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=2525
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Malva Garden" <noreply@example.com>

# Google Sign-In: one Client ID for API + web build (docs/GOOGLE_SIGNIN.md)
GOOGLE_CLIENT_ID=
# Optional; if empty, docker-compose uses GOOGLE_CLIENT_ID for web build
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NOVA_POSHTA_API_KEY=

# WayForPay — docs/PAYMENTS_WAYFORPAY.md (Production)
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET=
WAYFORPAY_MERCHANT_PASSWORD=
WAYFORPAY_MERCHANT_DOMAIN=malva-garden.com
# Defaults if WEB_ORIGIN + API_PUBLIC_ORIGIN are https://malva-garden.com (usually leave commented):
# WAYFORPAY_RETURN_URL=https://malva-garden.com/api/payment/wayforpay/return
# WAYFORPAY_SERVICE_URL=https://malva-garden.com/api/v1/payments/wayforpay/callback

# One-time seed only (do not use admin123 on prod):
# ADMIN_SEED_PASSWORD=
