PORT=4000
WEB_ORIGIN=http://localhost:3300
ADMIN_ORIGIN=http://localhost:3301
DATABASE_URL=postgresql://malva:malva@localhost:5432/malva_garden
JWT_SECRET=change-me-in-production
# Admin JWT: короткий access + refresh у БД (ротація при /admin/auth/refresh)
# ADMIN_ACCESS_TOKEN_TTL=15m
# ADMIN_REFRESH_TOKEN_TTL_DAYS=7
# ADMIN_LOGIN_RATE_LIMIT=10
# ADMIN_LOGIN_RATE_TTL_MS=900000
# Prod cookie mode (admin надсилає X-Admin-Auth: cookie + credentials):
# ADMIN_COOKIE_DOMAIN=.malva-garden.com
# ADMIN_COOKIE_SECURE=true
# Локально без SMTP: показувати verificationUrl у відповіді register / resend
EMAIL_VERIFICATION_DEV=true

# SMTP (production) — див. docs/EMAIL_SMTP.md
# SMTP_ENABLED=true
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Malva Garden" <noreply@yourdomain.com>

# Google Sign-In (customer account)
# GOOGLE_CLIENT_ID=
ADMIN_SEED_PASSWORD=admin123

# Public base URL of this API (HTTPS on production). Used for WayForPay serviceUrl and uploaded image URLs.
API_PUBLIC_ORIGIN=http://localhost:4000

# Local directory for uploaded images (served at /uploads/*). On production: Docker volume api_uploads.
UPLOAD_DIR=uploads

# WayForPay (https://wiki.wayforpay.com/)
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_login
WAYFORPAY_MERCHANT_SECRET=your_secret_key
WAYFORPAY_MERCHANT_PASSWORD=your_merchant_password
WAYFORPAY_MERCHANT_DOMAIN=your-store.example.com
# Optional overrides (defaults: WEB_ORIGIN/api/payment/wayforpay/return and API_PUBLIC_ORIGIN/.../callback)
# WAYFORPAY_RETURN_URL=
# WAYFORPAY_SERVICE_URL=

# Nova Poshta API 2.0 (https://developers.novaposhta.ua/) — довідники для checkout
NOVA_POSHTA_API_KEY=
