NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Публічна URL вітрини (canonical, Open Graph, sitemap). На Vercel можна не задавати — підставиться VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3300
# Google Search Console: лише значення content з meta-тега (без лапок). Див. docs/SEO_GOOGLE.md
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Google Sign-In client ID for customer account login/register.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
