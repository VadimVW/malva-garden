# Malva Garden — reverse proxy
# Домени: malva-garden.com (вітрина + /api/v1), admin.malva-garden.com (адмінка)
# IP :80 / :3001 — fallback до повного переходу на HTTPS-домени
#
# §14.1.3 — Basic Auth на адмінку (перед JWT-логіном):
#   ADMIN_BASIC_AUTH_USER + ADMIN_BASIC_AUTH_HASH у .env на VPS
#   Хеш: docker run --rm caddy:2-alpine caddy hash-password --plaintext '…'
#   У .env символ $ у хеші екрануйте як $$ (docker compose interpolation)

(admin_basicauth) {
	basicauth {
		{$ADMIN_BASIC_AUTH_USER} {$ADMIN_BASIC_AUTH_HASH}
	}
}

{
	email {$ACME_EMAIL}
}

# --- Production domains (HTTPS via Let's Encrypt) ---

www.malva-garden.com {
	redir https://malva-garden.com{uri} permanent
}

malva-garden.com {
	@api_v1 path /api/v1/*
	@uploads path /uploads/*
	handle @api_v1 {
		reverse_proxy api:4000
	}
	handle @uploads {
		reverse_proxy api:4000
	}
	@web_api path /api/*
	handle @web_api {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

admin.malva-garden.com {
	import admin_basicauth
	reverse_proxy admin:3000
}

# --- Fallback по IP (HTTP, без TLS) ---

:80 {
	@admin host admin.malva-garden.com
	handle @admin {
		import admin_basicauth
		reverse_proxy admin:3000
	}

	@api_v1 path /api/v1/*
	@uploads path /uploads/*
	handle @api_v1 {
		reverse_proxy api:4000
	}
	handle @uploads {
		reverse_proxy api:4000
	}
	@web_api path /api/*
	handle @web_api {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
	handle {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

:3001 {
	import admin_basicauth
	reverse_proxy admin:3000
}
