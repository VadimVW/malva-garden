# Malva Garden — reverse proxy
# Без доменів: вітрина :80, API /api + /uploads, адмінка :3001
# З доменами: розкоментуй блок TLS внизу та задай SITE_DOMAIN тощо в .env

{
	email {$ACME_EMAIL}
}

:80 {
	@api_v1 path /api/v1/*
	@uploads path /uploads/*
	handle @api_v1 {
		reverse_proxy api:4000
	}
	handle @uploads {
		reverse_proxy api:4000
	}
	# Next.js Route Handlers (WayForPay return POST → redirect)
	@web_api path /api/*
	handle @web_api {
		reverse_proxy web:3000
	}
	handle {
		reverse_proxy web:3000
	}
}

:3001 {
	reverse_proxy admin:3000
}

# --- Після появи DNS (приклад) ---
